generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Todo {
  id        String   @id @default(uuid())
  title     String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model User {
  id   String @id @default(uuid())
  name String
}
