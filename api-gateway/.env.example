# Server
PORT=3000
NODE_ENV=development

# HTTP
API_PREFIX=api
# Comma-separated list of allowed origins for CORS.
CORS_ORIGINS=http://localhost:5179,http://localhost:8080

# Persistence
# Prisma/SQLite connection URL. In Docker the DB file lives on a named volume.
# Use "file:./dev.db" for local Prisma CLI work from the api-gateway dir.
DATABASE_URL=file:/data/todos.db
