# Copy this file to .env and adjust values.
# Vite only exposes vars prefixed with VITE_ to client code.

# --- Vite dev server ---
# Port used by `pnpm dev` and Playwright's webServer.
PORT=5179

# --- App config (exposed to browser) ---
# Base URL of the backend API (Dockerfile forwards this as ARG at build time).
VITE_API_URL=http://localhost:3000

# --- Playwright ---
# Override the port Playwright boots its dev server on (defaults to PORT).
# PORT=5179
